REMNA_BASE_URL=https://your-panel-domain/api
REMNA_TOKEN=your_bearer_token

ROUTING_NAME=Glowshine
FAKE_DNS=true

# Дополнительные правила (через запятую):
# EXTRA_PROXY=domain:gemini.google.com,domain:generativelanguage.googleapis.com,domain:aistudio.google.com
# EXTRA_DIRECT=domain:mysite.ru
# EXTRA_BLOCK=domain:ads.example.com

# GITHUB_RAW_URL=https://raw.githubusercontent.com/hydraponique/roscomvpn-routing/refs/heads/main/HAPP/DEFAULT.JSON
# CHECK_INTERVAL=43200

# Фрагментация пакетов — обход DPI (true/false)
FRAGMENT_ENABLE=true
FRAGMENT_PACKETS=tlshello
FRAGMENT_LENGTH=50-100
FRAGMENT_INTERVAL=5
FRAGMENT_MAXSPLIT=100-200

# Шум — маскировка трафика (true/false)
NOISE_ENABLE=true
NOISE_PACKET_TYPE=base64
NOISE_PACKET=7nQBAAABAAAAAAAABnQtcmluZwZtc2VkZ2UDbmV0AAABAAE=
NOISE_DELAY=50
NOISE_RAND=1-1024
NOISE_RAND_RANGE=0-255
